{
  "name": "mobile-surfaces",
  "description": "Expo iOS starter for Live Activities, Dynamic Island, home-screen widgets, and iOS 18 control widgets.",
  "private": true,
  "license": "MIT",
  "author": "Glendon Chin <glendonchin@gmail.com>",
  "homepage": "https://github.com/glendonC/mobile-surfaces#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glendonC/mobile-surfaces.git"
  },
  "bugs": {
    "url": "https://github.com/glendonC/mobile-surfaces/issues"
  },
  "keywords": [
    "expo",
    "react-native",
    "ios",
    "live-activity",
    "activitykit",
    "dynamic-island",
    "widgetkit",
    "starter"
  ],
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "mobileSurfaces": {
    "addPackages": [
      "@mobile-surfaces/surface-contracts",
      "@mobile-surfaces/live-activity",
      "@bacons/apple-targets",
      "expo-application",
      "expo-build-properties"
    ],
    "addPlugins": [
      "@bacons/apple-targets",
      "expo-build-properties"
    ],
    "addInfoPlistKeys": [
      "NSSupportsLiveActivities",
      "NSSupportsLiveActivitiesFrequentUpdates",
      "UIBackgroundModes"
    ],
    "addEntitlementKeys": [
      "com.apple.security.application-groups"
    ],
    "widgetTargetDir": "apps/mobile/targets/widget",
    "minimumNodeMajor": 24,
    "minimumXcodeMajor": 26
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/{surface-contracts,live-activity,push}\" build",
    "clean": "pnpm -r --filter \"./packages/*\" clean",
    "preinstall": "npx only-allow pnpm",
    "dev:doctor": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/doctor.mjs",
    "dev:setup": "bash scripts/setup.sh",
    "surface:diagnose": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/diagnose.mjs",
    "surface:setup-apns": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/setup-apns.mjs",
    "surface:codegen": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/codegen.mjs",
    "surface:codegen:check": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/codegen.mjs --check",
    "release:version": "changeset version && node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/bump-fixture-schema-urls.mjs && node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/codegen.mjs",
    "surface:check": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/surface-check.mjs",
    "agents:build": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/build-agents-md.mjs",
    "agents:check": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/build-agents-md.mjs --check",
    "traps:check": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/validate-trap-catalog.mjs",
    "test:scripts": "node --experimental-strip-types --no-warnings=ExperimentalWarning --test scripts/*.test.mjs",
    "test:push": "pnpm --filter @mobile-surfaces/push test",
    "surface:rename": "node scripts/rename-starter.mjs",
    "mobile:dev": "pnpm --dir apps/mobile exec expo start --host lan",
    "mobile:dev-client": "pnpm --dir apps/mobile exec expo start --dev-client --host lan",
    "mobile:ios": "pnpm --dir apps/mobile exec expo start --ios",
    "mobile:sim": "bash scripts/mobile-ios-sim.sh",
    "mobile:bootstrap": "pnpm install && pnpm mobile:prebuild:ios",
    "mobile:prebuild:ios": "pnpm --dir apps/mobile exec expo prebuild --platform ios --clean",
    "mobile:run:ios": "pnpm --dir apps/mobile exec expo run:ios",
    "mobile:run:ios:device": "pnpm --dir apps/mobile exec expo run:ios --device",
    "mobile:build:ios": "pnpm --dir apps/mobile exec eas build --platform ios --profile development",
    "mobile:build:ios:sim": "pnpm --dir apps/mobile exec eas build --platform ios --profile development-simulator",
    "mobile:build:ios:preview": "pnpm --dir apps/mobile exec eas build --platform ios --profile preview",
    "mobile:push:sim": "bash scripts/push-simulator-notification.sh",
    "mobile:push:device:alert": "node scripts/send-apns.mjs --type=alert",
    "mobile:push:device:liveactivity": "node scripts/send-apns.mjs --type=liveactivity",
    "cli:dev": "pnpm --filter create-mobile-surfaces start",
    "cli:try": "node ./packages/create-mobile-surfaces/scripts/dev-try.mjs",
    "cli:try:existing": "node ./packages/create-mobile-surfaces/scripts/dev-try.mjs --existing",
    "cli:smoke": "pnpm --filter create-mobile-surfaces smoke",
    "cli:smoke:existing": "pnpm --filter create-mobile-surfaces smoke:existing",
    "cli:smoke:monorepo": "pnpm --filter create-mobile-surfaces smoke:monorepo",
    "cli:smoke:e2e": "pnpm --filter create-mobile-surfaces smoke:e2e",
    "cli:test": "pnpm --filter create-mobile-surfaces test",
    "site:build": "pnpm --filter @mobile-surfaces/site build",
    "typecheck": "pnpm build && pnpm --filter mobile-surfaces-app typecheck",
    "release:dry-run": "node scripts/release-dry-run.mjs",
    "release:fix": "node scripts/release-fix.mjs",
    "setup:hooks": "node scripts/setup-hooks.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "25.6.0",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "tsup": "8.5.1",
    "zod": "4.3.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": ">=5.0.0"
      }
    }
  }
}
