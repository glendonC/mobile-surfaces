---
import { getCollection } from "astro:content";
import { DOC_GROUPS, type DocGroup } from "../../content.config";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { READING_PATHS } from "../../config/readingPaths";
import trapCatalog from "../../../../../data/traps.json";

const allDocs = await getCollection("docs");
const docs = allDocs
  .map((doc) => ({
    slug: doc.id,
    title: doc.data.title,
    description: doc.data.description,
    order: doc.data.order,
    group: doc.data.group,
  }))
  .sort((a, b) => a.order - b.order);

const docsByGroup = DOC_GROUPS.map((group) => ({
  group,
  entries: docs.filter((d) => d.group === group),
})).filter((g) => g.entries.length > 0);

function docFor(slug: string) {
  return docs.find((d) => d.slug === slug);
}

type TrapEntry = { severity: "error" | "warning" | "info"; deprecated?: boolean };
const trapEntries = (trapCatalog.entries as TrapEntry[]).filter((t) => !t.deprecated);
const trapCounts = trapEntries.reduce(
  (acc, t) => {
    acc[t.severity] += 1;
    acc.total += 1;
    return acc;
  },
  { total: 0, error: 0, warning: 0, info: 0 },
);
---

<DocsLayout
  title="Documentation | Mobile Surfaces"
  description="Mobile Surfaces documentation hub: architecture, push, multi-surface, troubleshooting."
>
  <article class="docs-prose docs-index">
    <section class="docs-hero">
      <p class="docs-hero-eyebrow">Documentation</p>
      <h1>iOS Live Activities that don't silently fail.</h1>
      <p class="docs-hero-lede">
        Mobile Surfaces is a starter and reference architecture for Live
        Activities, Dynamic Island, home-screen widgets, and iOS 18 control
        widgets in Expo apps. Pick a path that matches your role, or browse
        the full reference.
      </p>
    </section>

    <section class="docs-section" aria-labelledby="reading-paths">
      <h2 id="reading-paths">Reading Paths</h2>
      <ul class="docs-persona-grid">
        {
          READING_PATHS.map((p) => (
            <li class="docs-persona-card">
              <header class="docs-persona-head">
                <p class="docs-persona-label">{p.label}</p>
                <p class="docs-persona-intro">{p.intro}</p>
              </header>
              <ol class="docs-persona-steps">
                {p.slugs.map((slug, i) => {
                  const doc = docFor(slug);
                  const stepNum = String(i + 1).padStart(2, "0");
                  const href = `/docs/${slug}?path=${p.id}&step=${i + 1}`;
                  return (
                    <li>
                      <a class="docs-persona-step" href={href}>
                        <span class="docs-persona-step-num">{stepNum}</span>
                        <span class="docs-persona-step-body">
                          <span class="docs-persona-step-title">
                            {doc?.title ?? slug}
                          </span>
                          {doc?.description && (
                            <span class="docs-persona-step-desc">
                              {doc.description}
                            </span>
                          )}
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ol>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="docs-section" aria-labelledby="full-reference">
      <h2 id="full-reference">Full Reference</h2>
      <div class="docs-reference">
        {
          docsByGroup.map(({ group, entries }) => (
            <div class="docs-reference-group">
              <h3 class="docs-reference-group-label">{group}</h3>
              <ul>
                {entries.map((d) => (
                  <li>
                    <a class="docs-reference-link" href={`/docs/${d.slug}`}>
                      <span class="docs-reference-title">{d.title}</span>
                      {d.description && (
                        <span class="docs-reference-desc">{d.description}</span>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="docs-section" aria-labelledby="trap-catalog">
      <h2 id="trap-catalog" class="docs-sr-only">Trap catalog</h2>
      <a
        class="docs-trap-tile"
        href="/traps"
        data-tooltip="Browse the full trap catalog"
        data-tooltip-pos="top"
      >
        <div class="docs-trap-tile-body">
          <p class="docs-trap-tile-eyebrow">Trap catalog</p>
          <p class="docs-trap-tile-title">
            Every iOS Live Activity silent-failure mode, with symptom and fix.
          </p>
          <p class="docs-trap-tile-meta">
            Generated from <code>data/traps.json</code>. Static rules ship with an
            enforcement script in the repo.
          </p>
        </div>
        <dl class="docs-trap-tile-stats">
          <div>
            <dt>Total</dt>
            <dd>{trapCounts.total}</dd>
          </div>
          <div>
            <dt>Errors</dt>
            <dd>{trapCounts.error}</dd>
          </div>
          <div>
            <dt>Warnings</dt>
            <dd>{trapCounts.warning}</dd>
          </div>
          <div>
            <dt>Info</dt>
            <dd>{trapCounts.info}</dd>
          </div>
        </dl>
      </a>
    </section>
  </article>
</DocsLayout>
