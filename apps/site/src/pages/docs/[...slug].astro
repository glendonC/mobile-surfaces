---
import { getCollection, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import PageActions from "../../components/PageActions.astro";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const origin = Astro.site
  ? new URL("/", Astro.site).origin
  : new URL(Astro.url).origin;
---

<DocsLayout
  title={`${entry.data.title} | Mobile Surfaces`}
  description={entry.data.description}
  currentSlug={entry.id}
>
  <article class="docs-prose">
    <header class="docs-prose-header">
      <h1>{entry.data.title}</h1>
      <PageActions
        slug={entry.id}
        title={entry.data.title}
        markdown={entry.body ?? ""}
        origin={origin}
      />
    </header>
    <Content />
  </article>
</DocsLayout>
