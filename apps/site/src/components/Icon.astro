      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <path d="M5 12.5l4.5 4.5L19 7.5" />
    </svg>
  )
}

{
  name === "close" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      class={extraClass}
    >
      <path d="M6 6l12 12" />
      <path d="M18 6L6 18" />
    </svg>
  )
}

{
  name === "chevron" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <path d="M9 6l6 6-6 6" />
    </svg>
  )
}

{
  name === "arrow-diagonal" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <path d="M7 17L17 7" />
