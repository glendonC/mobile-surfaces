---
// Inline SVG icons. Tiny, themable via currentColor, no library import.
// Each tile picks one so the bento has visual variety instead of six
// identical + glyphs.

interface Props {
  name:
    | "blueprint"
    | "people"
    | "trap"
    | "key"
    | "docs"
    | "github"
    | "arrow"
    | "plus"
    | "copy"
    | "check"
    | "close"
    | "chevron"
    | "arrow-diagonal";
  class?: string;
}

const { name, class: extraClass = "h-5 w-5" } = Astro.props;
---

{
  name === "blueprint" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <rect x="3" y="3" width="7" height="7" rx="1" />
      <rect x="14" y="3" width="7" height="4" rx="1" />
      <rect x="14" y="11" width="7" height="10" rx="1" />
      <rect x="3" y="14" width="7" height="7" rx="1" />
    </svg>
  )
}

{
  name === "people" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <circle cx="9" cy="9" r="3.2" />
      <circle cx="16.5" cy="10.5" r="2.4" />
      <path d="M3.5 19.5c0-2.8 2.5-5 5.5-5s5.5 2.2 5.5 5" />
      <path d="M14.5 17.5c.7-1.6 2.2-2.6 4-2.6 2 0 3.5 1.2 4 3" />
    </svg>
  )
}

{
  name === "trap" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <path d="M12 3v3" />
      <path d="M12 18v3" />
      <path d="M3 12h3" />
      <path d="M18 12h3" />
      <circle cx="12" cy="12" r="5" />
      <path d="M9 12a3 3 0 0 1 6 0" />
    </svg>
  )
}

{
  name === "key" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <circle cx="8" cy="14" r="4" />
      <path d="M11 13l9-9" />
      <path d="M16 8l3 3" />
      <path d="M14 6l3 3" />
    </svg>
  )
}

{
  name === "docs" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <path d="M5 4h9l5 5v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z" />
      <path d="M14 4v5h5" />
      <path d="M8 13h8" />
      <path d="M8 17h6" />
    </svg>
  )
}

{
  name === "github" && (
    <svg
      viewBox="0 0 24 24"
      fill="currentColor"
      class={extraClass}
    >
      <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.4-5.5-6 0-1.3.5-2.4 1.3-3.3-.1-.3-.5-1.6.1-3.3 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 3 .1 3.3.8.9 1.3 2 1.3 3.3 0 4.6-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3" />
    </svg>
  )
}

{
  name === "arrow" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={extraClass}
    >
      <path d="M5 12h14" />
      <path d="M13 6l6 6-6 6" />
    </svg>
  )
}

{
  name === "plus" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
