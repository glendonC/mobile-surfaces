# Cloudflare Pages headers. Path-specific rules merge with the /* block.
# Cache-Control here overrides the Pages default (public, max-age=0,
# must-revalidate) which otherwise applies to .css/.js/.svg/.png and to
# our llms-* endpoints regardless of the value the GET handler sets.

# Site-wide defaults: security headers on every response.
# CSP itself is delivered by Astro as a per-page <meta http-equiv>
# tag (experimental.csp in astro.config.mjs) so SHA-256 hashes for
# inline scripts/styles can stay in sync with the build automatically.
# X-Frame-Options replaces frame-ancestors (the meta tag delivery
# can't carry frame-ancestors).
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), browsing-topics=()
  Cross-Origin-Opener-Policy: same-origin

# Hash-named build artifacts are immutable — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# LLM endpoints — tolerate hour-stale; the underlying CLAUDE.md only
# changes on deploys.
/llms.txt
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/llms-full.txt
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Brand assets — moderate cache; rotate by editing the file.
/favicon.svg
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/og.png
  Cache-Control: public, max-age=86400
