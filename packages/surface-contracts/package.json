{
  "name": "@mobile-surfaces/surface-contracts",
  "version": "1.0.0",
  "description": "Shared LiveSurfaceSnapshot contract, generated fixtures, and ActivityKit/APNs mapping helpers for Mobile Surfaces.",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "homepage": "https://github.com/glendonC/mobile-surfaces#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glendonC/mobile-surfaces.git",
    "directory": "packages/surface-contracts"
  },
  "bugs": {
    "url": "https://github.com/glendonC/mobile-surfaces/issues"
  },
  "keywords": [
    "mobile-surfaces",
    "live-activity",
    "activitykit",
    "contract",
    "fixtures"
  ],
  "author": "Glendon Chin <glendonchin@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": "./schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "^4"
