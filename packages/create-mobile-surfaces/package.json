{
  "name": "create-mobile-surfaces",
  "version": "2.0.0",
  "description": "Guided installer for the Mobile Surfaces Expo iOS Live Activity starter.",
  "license": "MIT",
  "homepage": "https://github.com/glendonC/mobile-surfaces#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glendonC/mobile-surfaces.git",
    "directory": "packages/create-mobile-surfaces"
  },
  "bugs": {
    "url": "https://github.com/glendonC/mobile-surfaces/issues"
  },
  "keywords": [
    "mobile-surfaces",
    "create",
    "expo",
    "ios",
    "live-activity",
    "dynamic-island",
    "starter"
  ],
  "type": "module",
  "bin": {
    "create-mobile-surfaces": "./bin/index.mjs"
  },
  "files": [
    "bin",
    "src",
    "template"
  ],
  "author": "Glendon Chin <glendonchin@gmail.com>",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "start": "node ./bin/index.mjs",
    "try": "node ./scripts/dev-try.mjs",
    "try:existing": "node ./scripts/dev-try.mjs --existing",
    "smoke": "node ./scripts/dev-smoke.mjs",
    "smoke:existing": "node ./scripts/dev-smoke-existing.mjs",
    "smoke:monorepo": "node ./scripts/dev-smoke-monorepo.mjs",
    "test": "node --test test/*.test.mjs",
    "build:template": "node ./scripts/build-template.mjs",
    "prepublishOnly": "node ./scripts/build-template.mjs"
  },
  "dependencies": {
    "@inquirer/ansi": "2.0.5",
    "@inquirer/core": "11.1.9",
    "@inquirer/prompts": "8.4.2",
    "ora": "9.4.0",
    "picocolors": "1.1.1"
  }
}
