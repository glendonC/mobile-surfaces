{
  "name": "@mobile-surfaces/traps",
  "version": "8.0.0",
  "description": "Single home for the trap catalog, MobileSurfacesError base, URL builder, and generated TS/Swift bindings. Imported by every package that throws or reports diagnostics; not user-facing.",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./swift": "./swift/MobileSurfacesTraps.swift",
      "./package.json": "./package.json"
    }
  },
  "license": "MIT",
  "homepage": "https://github.com/glendonC/mobile-surfaces#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glendonC/mobile-surfaces.git",
    "directory": "packages/traps"
  },
  "bugs": {
    "url": "https://github.com/glendonC/mobile-surfaces/issues"
  },
  "keywords": [
    "mobile-surfaces",
    "traps",
    "errors",
    "catalog"
  ],
  "author": "Glendon Chin <glendonchin@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./swift": "./swift/MobileSurfacesTraps.swift",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "swift"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "4.3.6"
  }
}
