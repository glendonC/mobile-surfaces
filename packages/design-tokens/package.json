{
  "name": "@mobile-surfaces/design-tokens",
  "version": "2.0.1",
  "description": "Shared design tokens for the Mobile Surfaces React Native app and SwiftUI widget target.",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./tokens": "./tokens.json",
      "./package.json": "./package.json"
    }
  },
  "license": "MIT",
  "homepage": "https://github.com/glendonC/mobile-surfaces#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glendonC/mobile-surfaces.git",
    "directory": "packages/design-tokens"
  },
  "bugs": {
    "url": "https://github.com/glendonC/mobile-surfaces/issues"
  },
  "keywords": [
    "mobile-surfaces",
    "design-tokens",
    "live-activity",
    "widgetkit"
  ],
  "author": "Glendon Chin <glendonchin@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": "./tokens.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "tokens.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  }
}
