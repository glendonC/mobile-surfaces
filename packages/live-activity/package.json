{
  "name": "@mobile-surfaces/live-activity",
  "version": "1.2.0",
  "description": "Expo native module wrapping ActivityKit start/update/end and push token events for Mobile Surfaces.",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "homepage": "https://github.com/glendonC/mobile-surfaces#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glendonC/mobile-surfaces.git",
    "directory": "packages/live-activity"
  },
  "bugs": {
    "url": "https://github.com/glendonC/mobile-surfaces/issues"
  },
  "keywords": [
    "mobile-surfaces",
    "expo",
    "ios",
    "live-activity",
    "activitykit",
    "dynamic-island"
  ],
  "author": "Glendon Chin <glendonchin@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "ios",
    "expo-module.config.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "expo": ">=55",
    "react": ">=19.2",
    "react-native": ">=0.83"
  },
  "dependencies": {
    "@mobile-surfaces/surface-contracts": "workspace:*"
  }
}
